{
  "name": "@cypsela/gateway",
  "version": "0.0.0",
  "description": "eth.cypsela deployable site (CF Pages)",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-only",
  "author": "tabcat",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && vite build --config vite.sw.config.ts",
    "preview": "vite preview",
    "test": "vitest --dir test --config vitest.config.ts --run",
    "test:watch": "vitest --dir test --config vitest.config.ts",
    "test:e2e": "playwright test",
    "ci": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@cypsela/gateway-sw-core": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
